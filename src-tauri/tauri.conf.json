{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Diary Widget",
  "version": "0.1.0",
  "identifier": "com.liyu8.diarywidget",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Diary Widget",
        "width": 380,
        "height": 520,
        "minWidth": 320,
        "minHeight": 400,
        "alwaysOnTop": true,
        "transparent": true,
        "decorations": false,
        "skipTaskbar": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
